<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppMobile.HomePage"
             >
    
    
    <VerticalStackLayout>
        <Label 
            Text="Lista de tarefas:"
            VerticalOptions="Center" 
            HorizontalOptions="Center" FontSize="24"/>
        <SearchBar/>
        <CollectionView HeightRequest="600" x:Name="colTasks">

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <StackLayout Orientation="Horizontal" Margin="0, 10">
                        <CheckBox />
                        <StackLayout>
                            <Label  Text="{Binding Nome}"/>
                            <Label  Text="{Binding Data, StringFormat='{0:yyyy-MM-dd}'}"/>
                        </StackLayout>
                        <ImageButton  HorizontalOptions="EndAndExpand" WidthRequest="50" HeightRequest="40" Source="trash.png" Clicked="ImageButton_Clicked" />

                    </StackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Text="Adicionar tarefa" Clicked="AdicionarTarefa_Clicked" WidthRequest="250" VerticalOptions="End"/>
    </VerticalStackLayout>

    
    
    
    
    
</ContentPage>